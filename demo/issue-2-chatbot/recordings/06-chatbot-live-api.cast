[0.000, "o", "\u001b[0;32m╔══════════════════════════════════════════════════════════════╗\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m║  JBUG Korea Demo: AI Chatbot Live API                     ║\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m║  AI 챗봇 실시간 API 데모                                  ║\u001b[0m\r\n\u001b[0;32m║                                                            ║\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m║  Powered by: Quarkus + LangChain4j + Ollama (qwen3:1.7b) ║\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n"]
[2.005, "o", "\r\n"]
[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m  Step 1: Quarkus health check / 헬스체크\u001b[0m\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;33m$ curl -s http://localhost:8080/q/health | python3 -m json.tool\u001b[0m\r\n"]
[2.075, "o", "{\r\n    \u001b[1m\"status\"\u001b[0m: \u001b[32m\"UP\"\u001b[0m,\r\n    \u001b[1m\"checks\"\u001b[0m: [\r\n        {\r\n            \u001b[1m\"name\"\u001b[0m: \u001b[32m\"alive\"\u001b[0m,\r\n            \u001b[1m\"status\"\u001b[0m: \u001b[32m\"UP\"\u001b[0m\r\n        }\r\n    ]\r\n}\r\n"]
[2.016, "o", "\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m  Step 2: Existing Quote API / 기존 명언 API\u001b[0m\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;33m$ curl -s http://localhost:8080/api/quotes/random | python3 -m json.tool\u001b[0m\r\n"]
[1.099, "o", "{\r\n    \u001b[1m\"id\"\u001b[0m: \u001b[33m6\u001b[0m,\r\n    \u001b[1m\"text\"\u001b[0m: \u001b[32m\"Simplicity is the soul of efficiency.\"\u001b[0m,\r\n    \u001b[1m\"author\"\u001b[0m: \u001b[32m\"Austin Freeman\"\u001b[0m,\r\n    \u001b[1m\"category\"\u001b[0m: \u001b[32m\"inspiration\"\u001b[0m\r\n}\r\n"]
[2.017, "o", "\r\n"]
[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m  Step 3: AI Chatbot — Quote Explanation / 명언 해설\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1;33m$ curl -s -X POST http://localhost:8080/api/chat \\033[0m\r\n"]
[0.000, "o", "\u001b[1;33m    -H 'Content-Type: application/json' \\033[0m\r\n"]
[0.000, "o", "\u001b[1;33m    -d '{\"message\": \"Explain the Linus Torvalds quote about code\"}'\u001b[0m\r\n"]
[1.063, "o", "\r\n"]
[6.772, "o", "{\r\n    \u001b[1m\"response\"\u001b[0m: \u001b[32m\"Linus Torvalds' quote, **\\\"Talk is cheap. Show me the code.\\\"** emphasizes that abstract discussions about programming or technology are easy to engage in, but **actual implementation**—writing code that works—is the true measure of competence. It underscores the importance of **practical execution** over theoretical debate, highlighting that developers must focus on creating functional, reliable code rather than just discussing ideas. The quote serves as a reminder that **code is the ultimate proof of understanding** and dedication to a project.\"\u001b[0m\r\n}\r\n"]
[3.013, "o", "\r\n"]
[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m  Step 4: AI Chatbot — Korean / 한국어 질문\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1;33m$ curl -s -X POST http://localhost:8080/api/chat \\033[0m\r\n"]
[0.000, "o", "\u001b[1;33m    -d '{\"message\": \"Steve Jobs 명언의 의미를 설명해줘\"}'\u001b[0m\r\n"]
[1.009, "o", "\r\n"]
[7.336, "o", "{\r\n    \u001b[1m\"response\"\u001b[0m: \u001b[32m\"Steve Jobs의 명언은 창의성과 열정, 그리고 혁신을 강조합니다.  \\n1. **\\\"The only way to do great work is to love what you do.\\\"**  \\n   - 그는 열정을 바탕으로 일하는 것이 최고의 결과를 만들어내는 것이라고 말합니다. 일에 대한 사랑은 창의력과 동기부여를 주어, 성공을 이끌어냅니다.  \\n\\n2. **\\\"In the middle of difficulty lies opportunity.\\\"**  \\n   - 어려움 속에 기회가 있다며, 문제를 해결하는 과정에서 새로운 가능성들을 발견하게 되는 것을 의미합니다. Steve Jobs는 어려움을 극복하는 데 있어 기회를 찾는 능력이 중요하다고 강조합니다.  \\n\\n이 두 명언은 그가 과학, 디지털 기술, 디자인을 통해 세상을 변화시키는 데 필요한 **열정과 시야**를 반영합니다.\"\u001b[0m\r\n}\r\n"]
[3.015, "o", "\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m  Step 5: AI Chatbot — Recommendation / 명언 추천\u001b[0m\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n\u001b[1;33m$ curl -s -X POST http://localhost:8080/api/chat \\033[0m\r\n\u001b[1;33m    -d '{\"message\": \"I feel stuck. Recommend a quote.\"}'\u001b[0m\r\n"]
[1.014, "o", "\r\n"]
[3.867, "o", "{\r\n    \u001b[1m\"response\"\u001b[0m: \u001b[32m\"\\\"In the middle of difficulty lies opportunity.\\\" — Albert Einstein  \\nThis quote reminds us that even when facing tough challenges, there's often hidden potential. Embrace the difficulty as a catalyst for innovation and growth.\"\u001b[0m\r\n}\r\n"]
[3.020, "o", "\r\n"]
[0.000, "o", "\u001b[0;32m  ✓ AI Chatbot responds with context-aware answers!\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m  ✓ AI 챗봇이 명언 컨텍스트를 활용하여 답변합니다!\u001b[0m\r\n\r\n\u001b[0;32m  Tech stack: Quarkus 3.34.3 + LangChain4j + Ollama (qwen3:1.7b)\u001b[0m\r\n"]
