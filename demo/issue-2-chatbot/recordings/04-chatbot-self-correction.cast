[0.010, "o", "\u001b[0;32m║  JBUG Korea Demo: AI Chatbot Harness Self-Correction      ║\u001b[0m\r\n\u001b[0;32m║  AI 챗봇 하네스 자기 교정 데모                            ║\u001b[0m\r\n\u001b[0;32m║                                                            ║\u001b[0m\r\n\u001b[0;32m║  Agent writes bad code → Harness catches → Agent fixes    ║\u001b[0m\r\n\u001b[0;32m║  에이전트가 잘못된 코드 작성 → 하네스가 잡음 → 수정      ║\u001b[0m\r\n\u001b[0;32m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n"]
[3.024, "o", "\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m  Step 1: Agent writes ChatBotResource with violations / 위반 코드 작성\u001b[0m\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n  The agent created a chat endpoint but made mistakes:\r\n  에이전트가 챗봇 엔드포인트를 만들었지만 실수가 있습니다:\r\n\r\n"]
[1.057, "o", "\u001b[1;33m$ cat src/main/java/dev/tedwon/ChatBotResource.java\u001b[0m\r\n"]
[1.171, "o", "package dev.tedwon;\r\n\r\nimport jakarta.inject.Inject;\r\nimport jakarta.ws.rs.Consumes;\r\nimport jakarta.ws.rs.POST;\r\nimport jakarta.ws.rs.Path;\r\nimport jakarta.ws.rs.Produces;\r\nimport jakarta.ws.rs.core.MediaType;\r\n\r\n@Path(\"/api/chat\")\r\n@Consumes(MediaType.APPLICATION_JSON)\r\n@Produces(MediaType.APPLICATION_JSON)\r\npublic class ChatBotResource {\r\n\r\n    @Inject QuoteAiService quoteAiService;\r\n\r\n    @POST\r\n    public ChatResponse chat(ChatRequest request) {\r\n        System.out.println(\"Processing chat request: \" + request.message());\r\n        String aiResponse = quoteAiService.chat(request.message());\r\n        System.out.println(\"AI response: \" + aiResponse);\r\n        return new ChatResponse(aiResponse);\r\n    }\r\n}\r\n"]
