[0.000, "o", "\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m  Phase 3: Code Review / 코드 리뷰 단계\u001b[0m\r\n\u001b[0;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n  \u001b[2mIn Claude Code:\u001b[0m\r\n\r\n  \u001b[1;33m> /requesting-code-review\u001b[0m\r\n"]
